{
  "name": "donegeon",
  "private": true,
  "packageManager": "bun@1.1.0",
  "workspaces": [
    "packages/*"
  ],
  "catalog": {
    "@hono/zod-validator": "^0.1.0",
    "@kobalte/core": "^0.13.7",
    "@kobalte/tailwindcss": "^0.3.0",
    "@types/node": "^20.0.0",
    "autoprefixer": "^10.4.20",
    "bun-types": "^1.0.0",
    "eslint": "^8.0.0",
    "hono": "^4.0.0",
    "postcss": "^8.5.1",
    "solid-js": "^1.9.5",
    "@solidjs/router": "^0.15.3",
    "swagger-ui-dist": "^5.0.0",
    "tailwindcss": "^3.4.17",
    "turbo": "^2.7.4",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vite-plugin-solid": "^2.11.10",
    "vitest": "^1.0.0",
    "zod": "^3.25.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel --filter=@donegeon/backend --filter=@donegeon/frontend",
    "dev:backend": "turbo run dev --filter=@donegeon/backend",
    "dev:frontend": "turbo run dev --filter=@donegeon/frontend",
    "dev:openapi": "turbo run docs:serve --filter=@donegeon/docs",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules packages/**/node_modules"
  },
  "devDependencies": {
    "turbo": "catalog:",
    "typescript": "catalog:"
  }
}
